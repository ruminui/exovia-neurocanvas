{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exovia.local/schemas/live-evidence-room.schema.json",
  "title": "Exovia Live Evidence Room",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "roomId", "title", "revision", "participants", "evidenceAssets", "decisions", "executions", "events"],
  "properties": {
    "format": { "const": "exovia-live-room-v1" },
    "roomId": { "$ref": "#/$defs/id" },
    "projectId": { "$ref": "#/$defs/id" },
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "revision": { "type": "integer", "minimum": 0 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "participants": {
      "type": "array",
      "maxItems": 500,
      "items": { "$ref": "#/$defs/participant" }
    },
    "evidenceAssets": {
      "type": "array",
      "maxItems": 100000,
      "items": { "$ref": "#/$defs/evidenceAsset" }
    },
    "decisions": {
      "type": "array",
      "maxItems": 100000,
      "items": { "$ref": "#/$defs/decision" }
    },
    "executions": {
      "type": "array",
      "maxItems": 100000,
      "items": { "$ref": "#/$defs/execution" }
    },
    "events": {
      "type": "array",
      "maxItems": 500000,
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "participant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "displayName", "role", "capabilities"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["human", "agent", "workflow", "service"] },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 120 },
        "role": { "enum": ["observer", "contributor", "controller", "approver", "room_admin"] },
        "capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 120 }
        },
        "presence": { "enum": ["offline", "online", "away", "busy"] }
      }
    },
    "evidenceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assetId"],
      "properties": {
        "assetId": { "$ref": "#/$defs/id" },
        "startMs": { "type": "integer", "minimum": 0 },
        "endMs": { "type": "integer", "minimum": 0 },
        "region": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x": { "type": "number", "minimum": 0, "maximum": 1 },
            "y": { "type": "number", "minimum": 0, "maximum": 1 },
            "width": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
            "height": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          }
        },
        "quote": { "type": "string", "maxLength": 20000 }
      }
    },
    "evidenceAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "title", "provenance", "reviewState"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["text", "image", "audio", "video", "browser_event", "workflow_output", "agent_result"] },
        "title": { "type": "string", "minLength": 1, "maxLength": 300 },
        "mimeType": { "type": "string", "maxLength": 160 },
        "uri": { "type": "string", "maxLength": 4000 },
        "contentHash": { "type": "string", "maxLength": 256 },
        "durationMs": { "type": "integer", "minimum": 0 },
        "transcript": { "type": "string", "maxLength": 2000000 },
        "provenance": { "enum": ["human_sourced", "imported", "ai_proposed", "workflow_generated", "service_observed"] },
        "reviewState": { "enum": ["unreviewed", "human_reviewed", "approved", "rejected"] },
        "createdBy": { "$ref": "#/$defs/id" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "proposedBy", "status", "evidence", "revision"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "statement": { "type": "string", "minLength": 1, "maxLength": 20000 },
        "proposedBy": { "$ref": "#/$defs/id" },
        "approvedBy": { "$ref": "#/$defs/id" },
        "status": { "enum": ["proposed", "approved", "rejected", "superseded"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "revision": { "type": "integer", "minimum": 0 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidenceReference" }
        },
        "linkedExecutionIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "executionContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objective", "inputs", "allowedTools", "constraints", "expectedOutputs", "successCriteria", "approvalPolicy"],
      "properties": {
        "objective": { "type": "string", "minLength": 1, "maxLength": 10000 },
        "inputs": { "type": "array", "items": { "type": "string", "maxLength": 4000 } },
        "allowedTools": { "type": "array", "uniqueItems": true, "items": { "type": "string", "maxLength": 200 } },
        "constraints": { "type": "array", "items": { "type": "string", "maxLength": 4000 } },
        "expectedOutputs": { "type": "array", "items": { "type": "string", "maxLength": 4000 } },
        "successCriteria": { "type": "array", "minItems": 1, "items": { "type": "string", "maxLength": 4000 } },
        "approvalPolicy": { "enum": ["none", "before_external_action", "before_mutation", "always"] },
        "timeoutMs": { "type": "integer", "minimum": 1000, "maximum": 86400000 }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "actorId", "kind", "status", "contract", "inputRevision"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "actorId": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["agent", "workflow", "human_takeover", "service"] },
        "status": { "enum": ["queued", "running", "paused", "awaiting_approval", "completed", "failed", "cancelled"] },
        "contract": { "$ref": "#/$defs/executionContract" },
        "inputRevision": { "type": "integer", "minimum": 0 },
        "outputRevision": { "type": "integer", "minimum": 0 },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidenceReference" } },
        "approvedBy": { "$ref": "#/$defs/id" },
        "errorCode": { "type": "string", "maxLength": 160 }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sequence", "timestamp", "actorId", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "sequence": { "type": "integer", "minimum": 0 },
        "timestamp": { "type": "string", "format": "date-time" },
        "actorId": { "$ref": "#/$defs/id" },
        "type": {
          "enum": [
            "participant_joined", "participant_left", "graph_mutated", "evidence_added",
            "decision_proposed", "decision_reviewed", "execution_started", "execution_paused",
            "takeover_requested", "takeover_accepted", "takeover_returned", "execution_completed",
            "execution_failed", "recording_started", "recording_stopped"
          ]
        },
        "targetId": { "$ref": "#/$defs/id" },
        "executionId": { "$ref": "#/$defs/id" },
        "reason": { "type": "string", "maxLength": 4000 },
        "revision": { "type": "integer", "minimum": 0 },
        "metadata": { "type": "object" }
      }
    }
  }
}
